<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_space"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:gravity="center_horizontal">

        <!-- HEADER IMAGEN -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHeader"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#162447">

            <ImageView
                android:id="@+id/imgHeader"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/via_lactea"
                android:scaleType="centerCrop"
                android:contentDescription="@null"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- TITULO -->
        <TextView
            android:id="@+id/tvHeroTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LA VÍA LÁCTEA"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.10"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explora nuestra galaxia: estructura, historia, objetos y el lugar donde vivimos."
            android:textColor="#D0E6FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="14dp"/>

        <!-- MINI STATS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="14dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1E3A5F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100,000"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="años luz"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#162447">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="13.6B"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="años"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1B1B2F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+100B"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="estrellas"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- NAV INTERNA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explorar secciones"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="true"
            android:layout_marginBottom="14dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navCentro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#1E3A5F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕳 Centro"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sagitario A*"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navEstructura"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#162447">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌀 Estructura"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brazos y halo"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navObjetos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#1B1B2F">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ Objetos"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nebulosas, cúmulos..."
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navHistoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardCornerRadius="22dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#16213E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜 Historia"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Formación"
                        android:textColor="#B8D8FF"
                        android:textSize="12sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- ===== SECCIÓN: CENTRO ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionCentro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1E3A5F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/headerCentro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🕳 Centro galáctico (Sagitario A*)"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/arrowCentro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⌄"
                        android:textColor="#B8D8FF"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailsCentro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:src="@drawable/img_centro_galactico"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="10dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="En el centro de la Vía Láctea hay un agujero negro supermasivo. Su gravedad influye en la dinámica del núcleo y en las órbitas cercanas."
                        android:textColor="#D0E6FF"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\n• Objeto: agujero negro supermasivo\n• Región: núcleo galáctico\n• Evidencia: órbitas estelares rápidas alrededor del centro"
                        android:textColor="#B8D8FF"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECCIÓN: ESTRUCTURA ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionEstructura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#162447">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/headerEstructura"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌀 Estructura: bulbo, disco, brazos y halo"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/arrowEstructura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⌄"
                        android:textColor="#B8D8FF"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailsEstructura"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:src="@drawable/img_brazos_espirales"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="10dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="La Vía Láctea es una galaxia espiral barrada: tiene una barra central y brazos con formación estelar. El halo contiene estrellas viejas y cúmulos globulares."
                        android:textColor="#D0E6FF"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\n• Bulbo central: muchas estrellas antiguas\n• Disco: gas/polvo y brazos espirales\n• Halo: cúmulos globulares y materia oscura"
                        android:textColor="#B8D8FF"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECCIÓN: OBJETOS ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionObjetos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1B1B2F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/headerObjetos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✨ Objetos: nebulosas, cúmulos, supernovas"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/arrowObjetos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⌄"
                        android:textColor="#B8D8FF"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailsObjetos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:src="@drawable/img_nebulosa"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="10dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="En la galaxia existen regiones donde nacen estrellas (nebulosas), agrupaciones de estrellas (cúmulos) y restos de estrellas explotadas (supernovas)."
                        android:textColor="#D0E6FF"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\nEjemplos:\n• Nebulosa de Orión\n• Cúmulos globulares\n• Restos de supernova\n• Estrellas variables"
                        android:textColor="#B8D8FF"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECCIÓN: HISTORIA ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sectionHistoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/headerHistoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📜 Historia y formación"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/arrowHistoria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⌄"
                        android:textColor="#B8D8FF"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/detailsHistoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:src="@drawable/img_historia_via_lactea"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="10dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="La Vía Láctea se formó hace miles de millones de años con gas, polvo y fusiones con otras galaxias. Aún hoy sigue evolucionando."
                        android:textColor="#D0E6FF"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\nCuriosidad:\n• Un “año galáctico” (una vuelta del Sol al centro) dura ~225 millones de años."
                        android:textColor="#B8D8FF"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÓN A SISTEMA SOLAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSistemaSolar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Explorar Sistema Solar 🚀"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:cornerRadius="35dp"
            app:backgroundTint="#6C4AB6"
            app:elevation="12dp"/>

    </LinearLayout>
</ScrollView>